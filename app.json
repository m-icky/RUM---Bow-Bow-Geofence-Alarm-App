{
  "expo": {
    "newArchEnabled": true,
    "name": "Rum",
    "slug": "rum-alarm-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./rum.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./rum.png",
      "resizeMode": "contain",
      "backgroundColor": "#1c1412"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.rum",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Rum needs to access your location to alert you when entering your geofence boundary.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Rum needs background location access to trigger the alarm even when your screen is locked.",
        "NSLocationAlwaysUsageDescription": "Rum needs background location access to trigger the alarm even when your screen is locked.",
        "UIBackgroundModes": [
          "location",
          "audio",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./rum.png",
        "backgroundColor": "#1c1412"
      },
      "package": "com.example.rum",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Rum to track location in the background for commuter alarms.",
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-task-manager",
      "expo-audio",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "d12f6004-e9ef-4df9-a626-daccd9e52b98"
      }
    }
  }
}
